<Application x:Class="StarManager.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:StarManager.App"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="AppWindowBackgroundBrush" Color="#F4F6F8" />
        <SolidColorBrush x:Key="AppSurfaceBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="AppControlBackgroundBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="AppControlForegroundBrush" Color="#111827" />
        <SolidColorBrush x:Key="AppSecondaryForegroundBrush" Color="#374151" />
        <SolidColorBrush x:Key="AppBorderBrush" Color="#8B93A1" />
        <SolidColorBrush x:Key="AppAccentBrush" Color="#1D4ED8" />
        <SolidColorBrush x:Key="AppDataGridAltRowBrush" Color="#EEF2F7" />
        <SolidColorBrush x:Key="AppSelectionBrush" Color="#DCEBFF" />
        <SolidColorBrush x:Key="AppControlHoverBrush" Color="#F3F7FF" />
        <SolidColorBrush x:Key="AppControlPressedBrush" Color="#D7E7FF" />
        <SolidColorBrush x:Key="AppDisabledBackgroundBrush" Color="#F1F3F6" />
        <SolidColorBrush x:Key="AppDisabledForegroundBrush" Color="#636B78" />
        <SolidColorBrush x:Key="AppFocusBrush" Color="#1D4ED8" />
        <SolidColorBrush x:Key="AppTabActiveBackgroundBrush" Color="#E7F0FF" />
        <SolidColorBrush x:Key="AppBadgeRunningBackgroundBrush" Color="#E8F7EE" />
        <SolidColorBrush x:Key="AppBadgeRunningForegroundBrush" Color="#0F5132" />
        <SolidColorBrush x:Key="AppBadgeRunningBorderBrush" Color="#79C69B" />
        <SolidColorBrush x:Key="AppBadgeStoppedBackgroundBrush" Color="#F1F3F6" />
        <SolidColorBrush x:Key="AppBadgeStoppedForegroundBrush" Color="#374151" />
        <SolidColorBrush x:Key="AppBadgeStoppedBorderBrush" Color="#9CA3AF" />

        <Style x:Key="AppKeyboardFocusVisualStyle" TargetType="Control">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Control">
                        <Rectangle Margin="-2"
                                   Stroke="{DynamicResource AppFocusBrush}"
                                   StrokeThickness="2"
                                   RadiusX="3"
                                   RadiusY="3"
                                   SnapsToDevicePixels="True" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Window">
            <Setter Property="Background" Value="{DynamicResource AppWindowBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppControlForegroundBrush}" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource AppControlForegroundBrush}" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AppControlBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppControlForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FocusVisualStyle" Value="{StaticResource AppKeyboardFocusVisualStyle}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppControlHoverBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppControlPressedBrush}" />
                </Trigger>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AppFocusBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{DynamicResource AppDisabledBackgroundBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource AppDisabledForegroundBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource AppControlBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppControlForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FocusVisualStyle" Value="{StaticResource AppKeyboardFocusVisualStyle}" />
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AppFocusBrush}" />
                </Trigger>
                <Trigger Property="IsReadOnly" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{DynamicResource AppDisabledBackgroundBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource AppDisabledForegroundBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource AppControlBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppControlForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FocusVisualStyle" Value="{StaticResource AppKeyboardFocusVisualStyle}" />
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AppFocusBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{DynamicResource AppDisabledBackgroundBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource AppDisabledForegroundBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{DynamicResource AppControlBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppControlForegroundBrush}" />
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppControlHoverBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppSelectionBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource AppControlForegroundBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="{DynamicResource AppDisabledForegroundBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="{DynamicResource AppControlBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppControlForegroundBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppControlHoverBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppSelectionBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource AppControlForegroundBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="{DynamicResource AppDisabledForegroundBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource AppControlForegroundBrush}" />
            <Setter Property="FocusVisualStyle" Value="{StaticResource AppKeyboardFocusVisualStyle}" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="{DynamicResource AppDisabledForegroundBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="{DynamicResource AppControlBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppControlForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="{DynamicResource AppControlBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppControlForegroundBrush}" />
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppControlHoverBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="{DynamicResource AppDisabledForegroundBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="{DynamicResource AppControlBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppControlForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style TargetType="Separator">
            <Setter Property="Background" Value="{DynamicResource AppBorderBrush}" />
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppControlForegroundBrush}" />
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Background" Value="{DynamicResource AppControlBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppControlForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="FocusVisualStyle" Value="{StaticResource AppKeyboardFocusVisualStyle}" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppTabActiveBackgroundBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AppFocusBrush}" />
                    <Setter Property="BorderThickness" Value="1" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppControlHoverBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="{DynamicResource AppDisabledForegroundBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppControlForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="RowBackground" Value="{DynamicResource AppSurfaceBrush}" />
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource AppDataGridAltRowBrush}" />
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppControlForegroundBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppControlHoverBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppSelectionBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource AppControlForegroundBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource AppControlForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="FocusVisualStyle" Value="{StaticResource AppKeyboardFocusVisualStyle}" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppSelectionBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource AppControlForegroundBrush}" />
                </Trigger>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AppFocusBrush}" />
                    <Setter Property="BorderThickness" Value="1,1,1,1" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource AppControlBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppControlForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
        </Style>

        <Style TargetType="DataGridRowHeader">
            <Setter Property="Background" Value="{DynamicResource AppControlBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppControlForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
        </Style>
    </Application.Resources>
</Application>
