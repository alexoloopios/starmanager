<Window x:Class="StarManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:StarManager.App.Models"
        mc:Ignorable="d"
        Title="STAR Manager"
        Loaded="Window_OnLoaded"
        Closing="Window_OnClosing"
        PreviewKeyDown="Window_OnPreviewKeyDown"
        Height="680"
        Width="1120"
        MinHeight="520"
        MinWidth="900">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0"
                   Grid.ColumnSpan="2"
                   Text="STAR Setup Manager"
                   FontSize="26"
                   FontWeight="SemiBold"
                   Margin="0,0,0,10" />

        <Grid Grid.Row="1" Grid.Column="0" Margin="0,0,8,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox x:Name="StarPathTextBox"
                     Grid.Column="0"
                     TabIndex="0"
                     Height="34"
                     VerticalContentAlignment="Center"
                     IsReadOnly="True"
                     Margin="0,0,8,0" />

            <Button x:Name="BrowseButton"
                    Grid.Column="1"
                    Content="_Browse"
                    TabIndex="1"
                    Height="34"
                    Padding="16,0"
                    Margin="0,0,8,0"
                    Click="BrowseButton_OnClick" />

            <Button x:Name="ScanButton"
                    Grid.Column="2"
                    Content="_Scan"
                    TabIndex="2"
                    Height="34"
                    Padding="16,0"
                    Click="ScanButton_OnClick" />
        </Grid>

        <StackPanel Grid.Row="1"
                    Grid.Column="1"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="8,0,0,10">
            <TextBlock Text="Recent"
                   VerticalAlignment="Center"
                   Margin="0,0,8,0" />
            <ComboBox x:Name="RecentStarPathsComboBox"
                  Width="260"
                  Height="30"
                  TabIndex="3"
                  Margin="0,0,14,0"
                  ItemsSource="{Binding RecentStarPaths}"
                  SelectionChanged="RecentStarPathsComboBox_OnSelectionChanged" />

            <TextBlock Text="Theme"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0" />
            <ComboBox x:Name="ThemeComboBox"
                  TabIndex="4"
                      Width="120"
                      Height="30"
                      SelectionChanged="ThemeComboBox_OnSelectionChanged">
                <ComboBoxItem Content="System" IsSelected="True" />
                <ComboBoxItem Content="Dark" />
                <ComboBoxItem Content="Light" />
            </ComboBox>
        </StackPanel>

        <Border x:Name="ScanProgressBorder"
                Grid.Row="2"
                Grid.ColumnSpan="2"
                Margin="0,0,0,10"
                Padding="12,10"
                Background="{DynamicResource AppSurfaceBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock x:Name="ScanProgressTextBlock"
                           Grid.Row="0"
                           Margin="0,0,0,8"
                           FontWeight="SemiBold"
                           Text="Scanning STAR setup..." />

                <ProgressBar x:Name="ScanProgressBar"
                             Grid.Row="1"
                             Height="18"
                             Minimum="0"
                             Maximum="100"
                             Value="0" />
            </Grid>
        </Border>

        <TabControl x:Name="MainSectionsTabControl" Grid.Row="3" Grid.ColumnSpan="2" TabIndex="4">
            <TabItem x:Name="ProvidersTabItem" Header="Providers">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="280" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Provider filter"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />

                        <TextBox x:Name="ProviderSearchTextBox"
                                 Grid.Column="1"
                                 Height="32"
                                 VerticalContentAlignment="Center"
                                 TabIndex="5"
                                 Margin="0,0,8,0"
                                 ToolTip="Type part of a provider name to filter the list"
                                 TextChanged="ProviderSearchTextBox_OnTextChanged" />

                        <Button x:Name="ClearProviderSearchButton"
                                Grid.Column="2"
                                Content="Clear"
                                Height="32"
                                TabIndex="6"
                                Padding="12,0"
                                Click="ClearProviderSearchButton_OnClick" />

                        <CheckBox x:Name="ShowNeedingSetupOnlyCheckBox"
                              Grid.Column="3"
                              Content="Show only needing setup"
                              VerticalAlignment="Center"
                              Margin="12,0,10,0"
                              TabIndex="7"
                              Checked="ShowNeedingSetupOnlyCheckBox_OnCheckedChanged"
                              Unchecked="ShowNeedingSetupOnlyCheckBox_OnCheckedChanged" />

                        <TextBlock Grid.Column="4"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0"
                                   Foreground="{DynamicResource AppSecondaryForegroundBrush}"
                                   Text="Tip: providers show 'Configure first' until configured or started once." />
                    </Grid>

                    <WrapPanel Grid.Row="1" Margin="0,0,0,10">
                        <Button Content="Launch _STAR App"
                            TabIndex="8"
                                Height="34"
                                Padding="14,0"
                                Margin="0,0,10,0"
                                Click="LaunchStarAppButton_OnClick" />
                        <Button Content="Open _Coagulator Website"
                            TabIndex="9"
                                Height="34"
                                Padding="14,0"
                                Click="OpenCoagulatorWebsiteButton_OnClick" />
                    </WrapPanel>

                    <DataGrid x:Name="ProvidersDataGrid"
                              Grid.Row="2"
                              TabIndex="10"
                              KeyboardNavigation.TabNavigation="Once"
                              ItemsSource="{Binding ProvidersView}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              RowHeaderWidth="0"
                              GridLinesVisibility="Horizontal"
                              SelectionMode="Single"
                              SelectionChanged="ProvidersDataGrid_OnSelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Provider" Binding="{Binding Name}" Width="2*" />
                            <DataGridTextColumn Header="Hint" Binding="{Binding FirstLaunchHint}" Width="*" />
                            <DataGridTextColumn Header="Folder" Binding="{Binding FolderPath}" Width="3*" />
                            <DataGridTextColumn Header="Entry" Binding="{Binding EntryPath}" Width="3*" />

                            <DataGridTemplateColumn Header="Status" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate DataType="{x:Type models:ProviderItem}">
                                        <Border Padding="8,3"
                                                CornerRadius="11"
                                                BorderThickness="1"
                                                HorizontalAlignment="Left">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{DynamicResource AppBadgeStoppedBackgroundBrush}" />
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AppBadgeStoppedBorderBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding StatusText}" Value="Running">
                                                            <Setter Property="Background" Value="{DynamicResource AppBadgeRunningBackgroundBrush}" />
                                                            <Setter Property="BorderBrush" Value="{DynamicResource AppBadgeRunningBorderBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>

                                            <TextBlock Text="{Binding StatusText}" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource AppBadgeStoppedForegroundBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding StatusText}" Value="Running">
                                                                <Setter Property="Foreground" Value="{DynamicResource AppBadgeRunningForegroundBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Actions" Width="3*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate DataType="{x:Type models:ProviderItem}">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                            <Button Content="Configure"
                                                    IsTabStop="False"
                                                    Margin="0,0,6,0"
                                                    Padding="12,3"
                                                    Click="ConfigureProviderButton_OnClick"
                                                    Tag="{Binding}" />
                                            <Button Content="Start"
                                                    IsTabStop="False"
                                                    Margin="0,0,6,0"
                                                    Padding="12,3"
                                                    Click="StartProviderButton_OnClick"
                                                    Tag="{Binding}" />
                                            <Button Content="Stop"
                                                    IsTabStop="False"
                                                    Padding="12,3"
                                                    Click="StopProviderButton_OnClick"
                                                    Tag="{Binding}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                        <WrapPanel Grid.Row="3" Margin="0,10,0,0">
                        <TextBlock x:Name="SelectedProviderTextBlock"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"
                               FontWeight="SemiBold"
                               Text="Selected provider: none" />

                        <Button x:Name="ConfigureSelectedProviderButton"
                            Content="Configure selected"
                            TabIndex="11"
                            IsEnabled="False"
                            Margin="0,0,8,0"
                            Click="ConfigureSelectedProviderButton_OnClick" />

                        <Button x:Name="StartSelectedProviderButton"
                            Content="Start selected"
                            TabIndex="12"
                            IsEnabled="False"
                            Margin="0,0,8,0"
                            Click="StartSelectedProviderButton_OnClick" />

                        <Button x:Name="StopSelectedProviderButton"
                            Content="Stop selected"
                            TabIndex="13"
                            IsEnabled="False"
                            Click="StopSelectedProviderButton_OnClick" />
                        </WrapPanel>

                    <Expander Grid.Row="4"
                              Margin="0,10,0,0"
                              Header="Provider INI editor"
                              IsExpanded="False">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <WrapPanel Grid.Row="0" Margin="0,0,0,8">
                                <Button x:Name="LoadProviderIniButton"
                                        Content="Load selected INI"
                                        TabIndex="14"
                                        IsEnabled="False"
                                        Margin="0,0,8,0"
                                        Click="LoadProviderIniButton_OnClick" />

                                <Button x:Name="ReloadProviderIniButton"
                                        Content="Reload INI"
                                        TabIndex="15"
                                        IsEnabled="False"
                                        Margin="0,0,8,0"
                                        Click="ReloadProviderIniButton_OnClick" />

                                <Button x:Name="SaveProviderIniButton"
                                        Content="Save INI"
                                        TabIndex="16"
                                        IsEnabled="False"
                                        Click="SaveProviderIniButton_OnClick" />
                            </WrapPanel>

                            <TextBlock x:Name="SelectedProviderIniPathTextBlock"
                                       Grid.Row="1"
                                       Margin="0,0,0,8"
                                       Foreground="{DynamicResource AppSecondaryForegroundBrush}"
                                       Text="INI file: none loaded" />

                            <TextBox x:Name="ProviderIniEditorTextBox"
                                     Grid.Row="2"
                                     MinHeight="100"
                                     MaxHeight="240"
                                     AcceptsReturn="True"
                                     AcceptsTab="True"
                                     IsEnabled="False"
                                     TextWrapping="NoWrap"
                                     TextChanged="ProviderIniEditorTextBox_OnTextChanged"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto" />
                        </Grid>
                    </Expander>

                    <Expander Grid.Row="5"
                              Margin="0,10,0,0"
                              Header="Scan diagnostics"
                              IsExpanded="False">
                        <TextBox x:Name="ScanDiagnosticsTextBox"
                                 MinHeight="90"
                                 MaxHeight="200"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" />
                    </Expander>
                </Grid>
            </TabItem>

            <TabItem x:Name="CoagulatorsTabItem" Header="Coagulators">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="For advanced users hosting their own coagulator instance."
                               Margin="0,0,0,10" />

                    <WrapPanel Grid.Row="1" Margin="0,0,0,10">
                        <Button Content="_Start Local Coagulator"
                            TabIndex="8"
                                Height="34"
                                Padding="14,0"
                                Margin="0,0,10,0"
                                Click="StartCoagulatorButton_OnClick" />
                        <Button Content="S_top Local Coagulator"
                            TabIndex="9"
                                Height="34"
                                Padding="14,0"
                                Margin="0,0,10,0"
                                Click="StopCoagulatorButton_OnClick" />
                        <Button Content="Open C_oagulator Website"
                            TabIndex="10"
                                Height="34"
                                Padding="14,0"
                                Click="OpenCoagulatorWebsiteButton_OnClick" />
                        <TextBlock x:Name="CoagulatorStatusTextBlock"
                                   Margin="16,7,0,0"
                                   FontWeight="SemiBold"
                                   Text="Coagulator: Stopped" />
                    </WrapPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <TextBlock x:Name="StatusTextBlock"
                   Grid.Row="4"
                   Grid.ColumnSpan="2"
                   Margin="0,10,0,0"
                   FontWeight="SemiBold"
                   Text="Select your STAR folder to begin scanning." />

        <Expander Grid.Row="5"
                  Grid.ColumnSpan="2"
                  Margin="0,10,0,0"
                  Header="Activity log"
                  IsExpanded="False">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <WrapPanel Grid.Row="0" Margin="0,0,0,8">
                    <Button x:Name="ClearActivityLogButton"
                            Content="Clear log"
                            Click="ClearActivityLogButton_OnClick" />
                </WrapPanel>

                <TextBox x:Name="ActivityLogTextBox"
                         Grid.Row="1"
                         MinHeight="90"
                         MaxHeight="220"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" />
            </Grid>
        </Expander>
    </Grid>
</Window>
